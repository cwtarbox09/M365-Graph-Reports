# ─── Azure AD App Registration ─────────────────────────────────────────────────
# Create an app registration at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
#
# Required API Permissions (Delegated, requires admin consent):
#   - AuditLog.Read.All        (read sign-in audit logs)
#   - Directory.Read.All       (read user/device directory info)
#
# Required roles for the signing-in user (one of):
#   - Global Administrator
#   - Security Administrator
#   - Security Reader
#   - Global Reader
#   - Reports Reader
#
# Add Redirect URI (Web):
#   - http://localhost:3000/api/auth/callback/azure-ad      (local dev)
#   - https://your-app.vercel.app/api/auth/callback/azure-ad (production)

AZURE_AD_CLIENT_ID="your-client-id-here"
AZURE_AD_CLIENT_SECRET="your-client-secret-here"
AZURE_AD_TENANT_ID="your-tenant-id-here"

# ─── NextAuth ────────────────────────────────────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# Set to your deployment URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
